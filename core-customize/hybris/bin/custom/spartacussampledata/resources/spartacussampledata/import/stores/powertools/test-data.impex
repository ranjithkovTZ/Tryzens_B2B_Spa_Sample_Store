############ Order History ##########
INSERT_UPDATE Order;code[unique=true];user(uid);date[dateformat=dd.MM.yyyy HH:mm];currency(isocode)[default='USD'];net[default=false];deliveryMode(code)[default='standard-gross'];Discounts(code);calculated[default=false];store(uid);site(uid);deliveryCost;totalPrice;status(code)
;100004;powertools-test-user-with-orders@sap.cx.com;10.01.2019 10:40;;;;;;powertools;;5.26;35.50;COMPLETED

INSERT_UPDATE OrderEntry;order(code)[unique=true];product(code,catalogVersion(catalog(id),version))[unique=true];quantity[default=1];calculated[default=true];unit(code)[default='pieces'];entryNumber;basePrice;totalPrice
;100004;3881074:powertoolsProductCatalog:Online;;;;0;40.76;40.76
 
INSERT_UPDATE OrderHistoryEntry;order(code)[unique=true];timestamp[dateformat=dd.MM.yyyy HH:mm]
;100004;10.01.2019 10:40

